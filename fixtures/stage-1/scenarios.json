{
  "_format": {
    "description": "Stage-1 acceptance vectors for the external conformance oracle. The oracle runs against ONE freshly started system instance (empty store) connected to the same broker. It executes every scenario's 'steps' in array order (publishing JSON to the given topic, or a raw non-JSON string for 'publishRaw'), honoring 'settleMs' pauses so reference upserts land before the triggering purchase. After all steps it drains the 'notifications' topic from the beginning into a map of key -> latest value, then asserts that for each entry in 'expect', map[key] deep-equals the given value (numeric-tolerant; nulls significant). 'occurredAt' is echoed unchanged. The scenarios are deliberately ordered and use disjoint purchase keys so a single shared-store run is contamination-free; do not reorder them.",
    "topics_in": ["product-updates", "user-updates", "price-updates", "purchases"],
    "topic_out": "notifications"
  },
  "scenarios": [
    {
      "id": "AC1",
      "title": "happy path - all reference data present",
      "steps": [
        { "publish": { "topic": "product-updates", "key": "p1", "value": { "productId": "p1", "name": "Mechanical Keyboard", "category": "electronics" } } },
        { "publish": { "topic": "user-updates", "key": "u1", "value": { "userId": "u1", "name": "Alice", "email": "alice@example.com" } } },
        { "publish": { "topic": "price-updates", "key": "p1", "value": { "productId": "p1", "priceCents": 7999, "currency": "USD" } } },
        { "settleMs": 3000 },
        { "publish": { "topic": "purchases", "key": "buy1", "value": { "purchaseId": "buy1", "userId": "u1", "productId": "p1", "quantity": 2, "occurredAt": "2026-06-07T10:15:00Z" } } }
      ],
      "expect": [
        { "topic": "notifications", "key": "buy1", "value": { "purchaseId": "buy1", "userId": "u1", "userName": "Alice", "productId": "p1", "productName": "Mechanical Keyboard", "priceCents": 7999, "currency": "USD", "quantity": 2, "totalCents": 15998, "occurredAt": "2026-06-07T10:15:00Z" } }
      ]
    },
    {
      "id": "AC2",
      "title": "all reference data missing - nulls",
      "steps": [
        { "publish": { "topic": "purchases", "key": "buy2", "value": { "purchaseId": "buy2", "userId": "u-x", "productId": "p-x", "quantity": 3, "occurredAt": "2026-06-07T10:16:00Z" } } }
      ],
      "expect": [
        { "topic": "notifications", "key": "buy2", "value": { "purchaseId": "buy2", "userId": "u-x", "userName": null, "productId": "p-x", "productName": null, "priceCents": null, "currency": null, "quantity": 3, "totalCents": null, "occurredAt": "2026-06-07T10:16:00Z" } }
      ]
    },
    {
      "id": "AC3",
      "title": "only price known - total computed, names null",
      "steps": [
        { "publish": { "topic": "price-updates", "key": "p2", "value": { "productId": "p2", "priceCents": 500, "currency": "EUR" } } },
        { "settleMs": 3000 },
        { "publish": { "topic": "purchases", "key": "buy3", "value": { "purchaseId": "buy3", "userId": "u-x", "productId": "p2", "quantity": 4, "occurredAt": "2026-06-07T10:17:00Z" } } }
      ],
      "expect": [
        { "topic": "notifications", "key": "buy3", "value": { "purchaseId": "buy3", "userId": "u-x", "userName": null, "productId": "p2", "productName": null, "priceCents": 500, "currency": "EUR", "quantity": 4, "totalCents": 2000, "occurredAt": "2026-06-07T10:17:00Z" } }
      ]
    },
    {
      "id": "AC4",
      "title": "idempotent upsert - latest value wins",
      "steps": [
        { "publish": { "topic": "product-updates", "key": "p1", "value": { "productId": "p1", "name": "Keyboard", "category": "electronics" } } },
        { "publish": { "topic": "product-updates", "key": "p1", "value": { "productId": "p1", "name": "Mechanical Keyboard", "category": "electronics" } } },
        { "publish": { "topic": "user-updates", "key": "u1", "value": { "userId": "u1", "name": "Alice", "email": "alice@example.com" } } },
        { "publish": { "topic": "price-updates", "key": "p1", "value": { "productId": "p1", "priceCents": 7999, "currency": "USD" } } },
        { "settleMs": 3000 },
        { "publish": { "topic": "purchases", "key": "buy4", "value": { "purchaseId": "buy4", "userId": "u1", "productId": "p1", "quantity": 1, "occurredAt": "2026-06-07T10:18:00Z" } } }
      ],
      "expect": [
        { "topic": "notifications", "key": "buy4", "value": { "purchaseId": "buy4", "userId": "u1", "userName": "Alice", "productId": "p1", "productName": "Mechanical Keyboard", "priceCents": 7999, "currency": "USD", "quantity": 1, "totalCents": 7999, "occurredAt": "2026-06-07T10:18:00Z" } }
      ]
    },
    {
      "id": "AC5",
      "title": "poison message skipped - consumer survives",
      "steps": [
        { "publishRaw": { "topic": "price-updates", "key": "bad", "value": "this is not valid json" } },
        { "publish": { "topic": "product-updates", "key": "p1", "value": { "productId": "p1", "name": "Mechanical Keyboard", "category": "electronics" } } },
        { "publish": { "topic": "user-updates", "key": "u1", "value": { "userId": "u1", "name": "Alice", "email": "alice@example.com" } } },
        { "publish": { "topic": "price-updates", "key": "p1", "value": { "productId": "p1", "priceCents": 7999, "currency": "USD" } } },
        { "settleMs": 3000 },
        { "publish": { "topic": "purchases", "key": "buy5", "value": { "purchaseId": "buy5", "userId": "u1", "productId": "p1", "quantity": 1, "occurredAt": "2026-06-07T10:19:00Z" } } }
      ],
      "expect": [
        { "topic": "notifications", "key": "buy5", "value": { "purchaseId": "buy5", "userId": "u1", "userName": "Alice", "productId": "p1", "productName": "Mechanical Keyboard", "priceCents": 7999, "currency": "USD", "quantity": 1, "totalCents": 7999, "occurredAt": "2026-06-07T10:19:00Z" } }
      ]
    },
    {
      "id": "AC6",
      "title": "reference refresh - latest price used per purchase",
      "steps": [
        { "publish": { "topic": "user-updates", "key": "u1", "value": { "userId": "u1", "name": "Alice", "email": "alice@example.com" } } },
        { "publish": { "topic": "product-updates", "key": "p1", "value": { "productId": "p1", "name": "Mechanical Keyboard", "category": "electronics" } } },
        { "publish": { "topic": "price-updates", "key": "p1", "value": { "productId": "p1", "priceCents": 7999, "currency": "USD" } } },
        { "settleMs": 3000 },
        { "publish": { "topic": "purchases", "key": "buyA", "value": { "purchaseId": "buyA", "userId": "u1", "productId": "p1", "quantity": 1, "occurredAt": "2026-06-07T10:20:00Z" } } },
        { "settleMs": 2000 },
        { "publish": { "topic": "price-updates", "key": "p1", "value": { "productId": "p1", "priceCents": 8999, "currency": "USD" } } },
        { "settleMs": 3000 },
        { "publish": { "topic": "purchases", "key": "buyB", "value": { "purchaseId": "buyB", "userId": "u1", "productId": "p1", "quantity": 1, "occurredAt": "2026-06-07T10:21:00Z" } } }
      ],
      "expect": [
        { "topic": "notifications", "key": "buyA", "value": { "purchaseId": "buyA", "userId": "u1", "userName": "Alice", "productId": "p1", "productName": "Mechanical Keyboard", "priceCents": 7999, "currency": "USD", "quantity": 1, "totalCents": 7999, "occurredAt": "2026-06-07T10:20:00Z" } },
        { "topic": "notifications", "key": "buyB", "value": { "purchaseId": "buyB", "userId": "u1", "userName": "Alice", "productId": "p1", "productName": "Mechanical Keyboard", "priceCents": 8999, "currency": "USD", "quantity": 1, "totalCents": 8999, "occurredAt": "2026-06-07T10:21:00Z" } }
      ]
    }
  ]
}
